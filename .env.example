# Public frontend config. Safe to expose in the browser.
VITE_TELEGRAM_CHANNEL_URL=https://t.me/your_channel_or_group
VITE_GOOGLE_OAUTH_PROVIDER=firebase
VITE_GOOGLE_OAUTH_CLIENT_ID=replace_with_google_oauth_client_id
VITE_GOOGLE_OAUTH_REDIRECT_URI=https://reclaim-connect.vercel.app/oauth-callback.html

# Google Cloud → Web OAuth client → Authorized redirect URIs:
# https://reclaim-connect.vercel.app/oauth-callback.html
# http://localhost:5173/oauth-callback.html

# Firebase web app config (Firebase Console → Project settings → Your apps → Web)
VITE_FIREBASE_API_KEY=replace_with_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=replace_with_messaging_sender_id
VITE_FIREBASE_APP_ID=replace_with_firebase_app_id

# Private server config. Do not expose this in frontend code.
# Use this later from a backend/API route that calls the AI provider.
AI_API_KEY=replace_with_your_ai_api_key
